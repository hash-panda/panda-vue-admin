{
  "name": "panda-vue-admin",
  "version": "1.0.0",
  "description": "A comprehensive admin dashboard solution built with Vue 3, TypeScript, and Ant Design Vue components with AI Agent capabilities",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "vue": "^3.3.4",
    "typescript": "^5.0.2",
    "ant-design-vue": "^4.0.0",
    "@ant-design/icons-vue": "^7.0.0",
    "vue-router": "^4.2.0",
    "pinia": "^2.1.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.0",
    "@vue/tsconfig": "^0.4.0",
    "vite": "^4.3.0",
    "vue-tsc": "^1.6.0",
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.38.0",
    "eslint-plugin-vue": "^9.11.0",
    "prettier": "^2.8.7"
  },
  "keywords": [
    "vue",
    "admin",
    "dashboard",
    "typescript",
    "ant-design",
    "ai-agent"
  ],
  "author": "hash-panda",
  "license": "MIT"
}